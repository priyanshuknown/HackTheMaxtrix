## Phase 4: Urgency Engine

```python
def calculate_urgency(deadline_date, amount, category, request_history) -> dict:
    days_remaining = (deadline_date - date.today()).days
    
    # Category severity weights
    severity = {"exam_fee": 1.0, "interview_travel": 0.9, 
                "certification_fee": 0.7, "device_repair": 0.6}
    
    # Score calculation
    time_score = max(0, 100 - (days_remaining * 3))  # More urgent as deadline nears
    severity_score = severity[category] * 100
    urgency_score = (time_score * 0.6) + (severity_score * 0.4)
    
    level = "High" if urgency_score >= 70 else "Medium" if urgency_score >= 40 else "Low"
    
    # Review flag: pattern of repeated requests (approaching cap)
    review_flag = len(request_history) >= 1  # Flag if student already has prior request
    
    return {"urgency_level": level, "urgency_score": urgency_score, "review_flag": review_flag}
```

---

## Phase 5: Matching Engine

```python
def match_funders(request, funders) -> list:
    ranked = []
    for funder in funders:
        # Category fit (binary)
        cat_fit = 1.0 if request.category in funder.categories_supported else 0.0
        
        # Balance ratio (can they cover it?)
        balance_ratio = min(funder.available_balance / request.amount, 1.0)
        
        # Speed score (inverse of avg payout days, normalized)
        speed_score = max(0, 1.0 - (funder.avg_payout_days / 30))
        
        # Composite score
        score = (cat_fit * 0.5) + (balance_ratio * 0.3) + (speed_score * 0.2)
        
        if cat_fit > 0:  # Only include funders that support this category
            ranked.append({"funder_id": funder.id, "match_score": round(score, 3)})
    
    return sorted(ranked, key=lambda x: x["match_score"], reverse=True)
```

